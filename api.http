# Churches — protected
###############################################################################

### Create church
# @name createChurch
POST {{baseUrl}}/api/churches
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Grace Community Church",
  "address": "123 Main Street, Phnom Penh",
  "phone": "+855123456789",
  "email": "info@gracechurch.org",
  "website": "https://gracechurch.org",
  "pastor_name": "Pastor John Smith",

# Application
APP_ENV=development
APP_VERSION=1.0.0
APP_PORT=8080

# Default dev user (seeded on startup when APP_ENV=development)
SEED_DEFAULT_USER=true
DEFAULT_USER_EMAIL=ezra@gmail.com
DEFAULT_USER_PASSWORD=qwer1234

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ezradb
DB_SSLMODE=disable
DB_TIMEZONE=UTC

# JWT
JWT_SECRET=super-secret-key
JWT_TOKEN_EXPIRY=10

# Auth OTP toggles
# AUTH_REGISTER_OTP_REQUIRED=true  -> /auth/register requires a verified email OTP first
# AUTH_REGISTER_OTP_REQUIRED=false -> /auth/register skips OTP verification entirely
AUTH_REGISTER_OTP_REQUIRED=true
# AUTH_LOGIN_OTP_REQUIRED=true  -> /auth/login always requires a verified "login" OTP (2FA)
# AUTH_LOGIN_OTP_REQUIRED=false -> /auth/login only checks OTP if the client sends otp_code
AUTH_LOGIN_OTP_REQUIRED=false

# OAuth
GOOGLE_CLIENT_ID=

# Email (SMTP)
EMAIL_ENABLED=true
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USERNAME=development@komplech.com
SMTP_PASSWORD=G7x!pQ2vLm
SMTP_FROM=ezra@komplech.com
SMTP_SECURE=ssl

# Firebase Cloud Messaging
FIREBASE_ENABLED=false
FIREBASE_CREDENTIALS_PATH=

# PayWay payment gateway
PAYWAY_ENABLED=false
PAYWAY_MERCHANT_ID=
PAYWAY_API_KEY=
PAYWAY_API_USERNAME=
PAYWAY_BASE_URL=
PAYWAY_RETURN_URL=
PAYWAY_CONTINUE_URL=
PAYWAY_CALLBACK_URL=

# AWS S3 (Profile Image uploads)
AWS_S3_ENABLED=true
AWS_S3_BUCKET=s3-ezra
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=true

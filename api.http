  "token": "fcm_device_token_string_here",
  "platform": "ios"
}

### Unregister device token
POST {{baseUrl}}/api/device-tokens/unregister
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "token": "fcm_device_token_string_here"
}

### Clear all device tokens
DELETE {{baseUrl}}/api/device-tokens/clear
Authorization: Bearer {{token}}

###############################################################################
# Donations — public
###############################################################################

### Get all donations
GET {{baseUrl}}/donations

### Get donations (filtered)
GET {{baseUrl}}/donations?type=donate&donor_type=user&status=completed&page=1&page_size=20

### Get donation stats
GET {{baseUrl}}/donations/stats

### Get donation by ID
GET {{baseUrl}}/donations/{{donationId}}

### Get donations by type
GET {{baseUrl}}/donations/type/donate

### Get donations by event
GET {{baseUrl}}/donations/event/{{eventId}}

### Get event donation stats
GET {{baseUrl}}/donations/event/{{eventId}}/stats

### Check QR payment status
GET {{baseUrl}}/donations/{{donationId}}/status

### Initiate payment
POST {{baseUrl}}/donations/{{donationId}}/pay

### Regenerate QR code
POST {{baseUrl}}/donations/{{donationId}}/regenerate-qr

### PayWay webhook (internal)
POST {{baseUrl}}/webhooks/payway
Content-Type: application/json

{
  "tran_id": "DON-123-1705318200",
  "status": "success",
  "approval_code": "123456",
  "payment_option": "khqr",
  "hash": "base64_signature"
}

###############################################################################
# Donations — protected
###############################################################################

### Create donation (authenticated user)
# @name createDonation
POST {{baseUrl}}/api/donations
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "type": "donate",
  "donor_type": "user",
  "amount": 50.0,
  "currency": "USD",
  "message": "Happy to support!",
  "event_id": {{eventId}},
  "initiate_payment": false
}

### Create company sponsorship donation
POST {{baseUrl}}/api/donations
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "type": "sponsor",
  "donor_type": "company",
  "company_name": "Tech Solutions Ltd",
  "company_email": "sponsor@techsolutions.com",
  "company_phone": "+855123456789",
  "amount": 5000.0,
  "currency": "USD",
  "message": "Proud to sponsor this event!",
  "event_id": {{eventId}},
  "initiate_payment": false
}

### Get user's donations
GET {{baseUrl}}/api/donations/user
Authorization: Bearer {{token}}

### Get user's donations (limit/offset)
GET {{baseUrl}}/api/donations/user?limit=20&offset=0
Authorization: Bearer {{token}}

### Update donation status
PUT {{baseUrl}}/api/donations/{{donationId}}/status
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "completed",
  "transaction_id": "TXN-12345",
  "payment_method": "khqr"
}

### Delete donation
DELETE {{baseUrl}}/api/donations/{{donationId}}
Authorization: Bearer {{token}}


Authorization: Bearer {{token}}

###############################################################################
# Bands (protected)
###############################################################################

### Create band
# @name createBand
POST {{baseUrl}}/api/bands
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Worship Team Alpha",
  "description": "Main Sunday worship band",
  "cover": "https://example.com/bands/alpha.jpg",
  "is_public": true
}

### Get all bands
GET {{baseUrl}}/api/bands
Authorization: Bearer {{token}}

### Get all bands (paginated)
GET {{baseUrl}}/api/bands?page=1&page_size=20
Authorization: Bearer {{token}}

### Get user's bands
GET {{baseUrl}}/api/bands/user
Authorization: Bearer {{token}}

### Get public bands
GET {{baseUrl}}/api/bands/public
Authorization: Bearer {{token}}

### Get band by ID
GET {{baseUrl}}/api/bands/{{bandId}}
Authorization: Bearer {{token}}

### Update band
PUT {{baseUrl}}/api/bands/{{bandId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Worship Team Alpha",
  "description": "Updated description",
  "cover": "https://example.com/bands/alpha.jpg",
  "is_public": true
}

### Delete band
DELETE {{baseUrl}}/api/bands/{{bandId}}
Authorization: Bearer {{token}}

### Get band music
GET {{baseUrl}}/api/bands/{{bandId}}/musics
Authorization: Bearer {{token}}

### Add music to band
POST {{baseUrl}}/api/bands/{{bandId}}/musics
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "music_ids": [1, 2, 3]
}

### Reorder band music
PUT {{baseUrl}}/api/bands/{{bandId}}/musics/reorder
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "music_orders": [
    { "music_id": 2, "display_order": 1 },
    { "music_id": 1, "display_order": 2 },
    { "music_id": 3, "display_order": 3 }
  ]
}

### Remove music from band
DELETE {{baseUrl}}/api/bands/{{bandId}}/musics/{{musicId}}
Authorization: Bearer {{token}}

### Get band members
GET {{baseUrl}}/api/bands/{{bandId}}/members
Authorization: Bearer {{token}}

###############################################################################
# Chat (protected)
###############################################################################

### Create private conversation
# @name createConversation
POST {{baseUrl}}/api/chat/conversations
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "type": "private",
  "member_ids": [2]
}

### Create group conversation
POST {{baseUrl}}/api/chat/conversations
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "type": "group",
  "name": "Worship Planning",
  "member_ids": [2, 3, 4]
}

### Create band conversation
POST {{baseUrl}}/api/chat/conversations
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "type": "band",
  "band_id": {{bandId}},
  "member_ids": []
}

### Get conversations
GET {{baseUrl}}/api/chat/conversations
Authorization: Bearer {{token}}

### Get conversation by ID
GET {{baseUrl}}/api/chat/conversations/{{conversationId}}
Authorization: Bearer {{token}}

### Delete conversation
DELETE {{baseUrl}}/api/chat/conversations/{{conversationId}}
Authorization: Bearer {{token}}

### Get conversation members
GET {{baseUrl}}/api/chat/conversations/{{conversationId}}/members
Authorization: Bearer {{token}}

### Add conversation member
POST {{baseUrl}}/api/chat/conversations/{{conversationId}}/members
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "user_id": {{userId}},
  "role": "member"
}

### Update conversation member
PUT {{baseUrl}}/api/chat/conversations/{{conversationId}}/members/{{memberId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "role": "admin",
  "can_send": true
}

### Remove conversation member
DELETE {{baseUrl}}/api/chat/conversations/{{conversationId}}/members/{{memberId}}
Authorization: Bearer {{token}}

### Send text message
# @name sendMessage
POST {{baseUrl}}/api/chat/conversations/{{conversationId}}/messages
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "message_type": "text",
  "content": "Hello team!"
}

### Send voice message
POST {{baseUrl}}/api/chat/conversations/{{conversationId}}/messages
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "message_type": "voice",
  "media_url": "https://example.com/voice/note.mp3",
  "duration": 15,
  "content": "Voice note caption"
}

### Send image message
POST {{baseUrl}}/api/chat/conversations/{{conversationId}}/messages
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "message_type": "image",
  "media_url": "https://example.com/images/photo.jpg",
  "content": "Check this out"
}

### Share songs in chat
POST {{baseUrl}}/api/chat/conversations/{{conversationId}}/messages
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "message_type": "song",
  "music_ids": [1, 2]
}

### Get messages
GET {{baseUrl}}/api/chat/conversations/{{conversationId}}/messages
Authorization: Bearer {{token}}

### Get messages (paginated)
GET {{baseUrl}}/api/chat/conversations/{{conversationId}}/messages?page=1&page_size=50
Authorization: Bearer {{token}}

### Get message by ID
GET {{baseUrl}}/api/chat/conversations/{{conversationId}}/messages/{{messageId}}
Authorization: Bearer {{token}}

### Delete message
DELETE {{baseUrl}}/api/chat/conversations/{{conversationId}}/messages/{{messageId}}
Authorization: Bearer {{token}}

###############################################################################
# Settings (protected)
###############################################################################

### Get settings
GET {{baseUrl}}/api/settings
Authorization: Bearer {{token}}

### Update settings
PUT {{baseUrl}}/api/settings
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "language": "en",
  "theme": "dark",
  "notify_on_booking": true,
  "notify_on_music": true,
  "notify_on_event": true,
  "enable_push_notifications": false
}

### Reset settings to defaults
POST {{baseUrl}}/api/settings/reset
Authorization: Bearer {{token}}

###############################################################################
# Notifications (protected)
###############################################################################

### Create notification (specific user)
# @name createNotification
POST {{baseUrl}}/api/notifications
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "user_id": {{userId}},
  "title": "New Booking Confirmation",
  "message": "Your booking has been confirmed",
  "type": "booking",
  "related_type": "booking",
  "related_id": 1
}

### Create band notification
POST {{baseUrl}}/api/notifications/band/{{bandId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "New Song Added",
  "message": "Amazing Grace has been added to the band repertoire",
  "type": "music",
  "related_type": "music",
  "related_id": 1
}

### Create broadcast notification
POST {{baseUrl}}/api/notifications/broadcast
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "System Maintenance",
  "message": "Scheduled maintenance on Sunday at 2 AM",
  "type": "warning"
}

### Get all notifications
GET {{baseUrl}}/api/notifications
Authorization: Bearer {{token}}

### Get notifications (paginated)
GET {{baseUrl}}/api/notifications?page=1&page_size=20
Authorization: Bearer {{token}}

### Get unread notifications
GET {{baseUrl}}/api/notifications/unread
Authorization: Bearer {{token}}

### Get unread count
GET {{baseUrl}}/api/notifications/unread/count
Authorization: Bearer {{token}}

### Get notification by ID
GET {{baseUrl}}/api/notifications/{{notificationId}}
Authorization: Bearer {{token}}

### Mark notification as read
PUT {{baseUrl}}/api/notifications/{{notificationId}}/read
Authorization: Bearer {{token}}

### Mark all notifications as read
PUT {{baseUrl}}/api/notifications/read-all
Authorization: Bearer {{token}}

### Delete notification
DELETE {{baseUrl}}/api/notifications/{{notificationId}}
Authorization: Bearer {{token}}

### Delete all notifications
DELETE {{baseUrl}}/api/notifications
Authorization: Bearer {{token}}

###############################################################################
# Device tokens (protected)
###############################################################################

### Register device token
POST {{baseUrl}}/api/device-tokens/register
Authorization: Bearer {{token}}

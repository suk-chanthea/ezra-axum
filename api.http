Authorization: Bearer {{token}}

### Get pending members (owner only)
GET {{baseUrl}}/api/churches/{{churchId}}/pending
Authorization: Bearer {{token}}

### Approve or reject member (owner only)
POST {{baseUrl}}/api/churches/{{churchId}}/approve
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "user_id": {{userId}},
  "status": "approved"
}

### Update church (owner only)
PUT {{baseUrl}}/api/churches/{{churchId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Grace Community Church",
  "address": "123 Main Street, Phnom Penh",
  "phone": "+855123456789",
  "email": "info@gracechurch.org",
  "website": "https://gracechurch.org",
  "pastor_name": "Pastor John Smith",
  "description": "Updated description",
  "logo": "https://example.com/logos/grace-church.png",
  "established_date": "1995-06-15",
  "denomination": "Baptist"
}

### Delete church (owner only)
DELETE {{baseUrl}}/api/churches/{{churchId}}
Authorization: Bearer {{token}}

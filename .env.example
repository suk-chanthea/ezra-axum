# Application
APP_ENV=development
APP_VERSION=1.0.0
APP_PORT=8080

# Default dev user (seeded on startup when APP_ENV=development)
SEED_DEFAULT_USER=true
DEFAULT_USER_EMAIL=ezra@gmail.com
DEFAULT_USER_PASSWORD=qwer1234

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ezradb
DB_SSLMODE=disable
DB_TIMEZONE=UTC

# JWT
JWT_SECRET=super-secret-key
JWT_TOKEN_EXPIRY=10

# OAuth
GOOGLE_CLIENT_ID=

# Email (SMTP)
EMAIL_ENABLED=true
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USERNAME=development@komplech.com
SMTP_PASSWORD=G7x!pQ2vLm
SMTP_FROM=ezra@komplech.com
SMTP_SECURE=ssl

# Firebase Cloud Messaging
FIREBASE_ENABLED=false
FIREBASE_CREDENTIALS_PATH=

# PayWay payment gateway
PAYWAY_ENABLED=false
PAYWAY_MERCHANT_ID=
PAYWAY_API_KEY=
PAYWAY_API_USERNAME=
PAYWAY_BASE_URL=
PAYWAY_RETURN_URL=
PAYWAY_CONTINUE_URL=

### Ezra API — HTTP Client collection
### Works with VS Code REST Client, IntelliJ HTTP Client, and Cursor.
### 1. Run "Login" (or Register flow) first to populate @token.
### 2. Update placeholder IDs (@sessionId, @musicId, @eventId, etc.) from responses.

@baseUrl = http://localhost:8080
@token = eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJzdWIiOjEsInVzZXJuYW1lIjoiZXpyYUBnbWFpbC5jb20iLCJyb2xlIjoidXNlciIsImV4cCI6MTc5MTkwMzIyNX0.a3m58LfXrIZHUhBbHGS1cWVpDifABb8m0dKcleEGOak

# Default dev user (auto-seeded on startup in development)
@defaultEmail = ezra@gmail.com
@defaultPassword = qwer1234

# Placeholder resource IDs — replace after creating resources
@musicId = 1
@eventId = 1
@bookingId = 1
@bandId = 1
@conversationId = 1
@messageId = 1
@memberId = 2
@notificationId = 1
@donationId = 1
@supporterId = 1
@churchId = 1
@userId = 2
@sessionId = 1
@denomination = Baptist

###############################################################################
# Health
###############################################################################

### Ping
GET {{baseUrl}}/ping

###############################################################################
# Auth & OTP (public)
###############################################################################

### Send OTP — email verification
# @name Send OTP
POST {{baseUrl}}/otp/send
Content-Type: application/json

{
  "email": "sukchanthea@gmail.com",
  "purpose": "email_verification"
}

### Send OTP — login (2FA)
POST {{baseUrl}}/otp/send
Content-Type: application/json

{
  "email": "john@example.com",
  "purpose": "login"
}

### Send OTP — password reset
POST {{baseUrl}}/otp/send
Content-Type: application/json

{
  "email": "john@example.com",
  "purpose": "password_reset"
}

### Verify OTP
POST {{baseUrl}}/otp/verify
Content-Type: application/json

{
  "email": "john@example.com",
  "code": "123456",
  "purpose": "email_verification"
}

### Register (requires verified OTP)
# @name register
POST {{baseUrl}}/register
Content-Type: application/json

{
  "name": "John Doe",
  "email": "johndoe@gmail.com",
  "password": "qwer1234",
  "profile": "default.png",
  "otp_code": "123456",
  "device_id": "phone-android-001",
  "device_name": "Samsung Galaxy S24"
}

### Login (default dev user)
# @name login
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "{{defaultEmail}}",
  "password": "{{defaultPassword}}",
  "device_id": "web-browser-001",
  "device_name": "Chrome on MacBook"
}

### Login with 2FA OTP
# @name login2fa
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "johndoe",
  "password": "password123",
  "otp_code": "123456",
  "device_id": "mobile-001",
  "device_name": "iPhone 15 Pro"
}

### Google Login
POST {{baseUrl}}/auth/google
Content-Type: application/json

{
  "id_token": "GOOGLE_ID_TOKEN_HERE"
}

### Reset Password (requires verified OTP)
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "email": "john@example.com",
  "new_password": "newpassword123",
  "otp_code": "123456"
}

### Capture token from login response (run Login above, then use this line)
#@token = {{login.response.body.token}}

###############################################################################
# User (protected)
###############################################################################

### Get current user
GET {{baseUrl}}/api/me
Authorization: Bearer {{token}}

### Update profile
PUT {{baseUrl}}/api/me
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "username": "johndoe",
  "name": "John Doe",
  "profile": "https://example.com/avatar.jpg",
  "phone": "+855123456789",
  "birthday": "1990-01-15",
  "bio": "Worship leader"
}

### Logout (current session)
POST {{baseUrl}}/api/logout
Authorization: Bearer {{token}}

### Logout all devices
POST {{baseUrl}}/api/logout/all
Authorization: Bearer {{token}}

### Delete user account
DELETE {{baseUrl}}/api/user
Authorization: Bearer {{token}}

###############################################################################
# Sessions (protected)
###############################################################################

### List all active sessions
GET {{baseUrl}}/api/sessions
Authorization: Bearer {{token}}

### Revoke a specific session by ID
DELETE {{baseUrl}}/api/sessions/{{sessionId}}
Authorization: Bearer {{token}}

###############################################################################
# Users Directory Administration (protected, admin only)
###############################################################################

### List all users (admin only)
GET {{baseUrl}}/api/users
Authorization: Bearer {{token}}

### List all users paginated (admin only)
GET {{baseUrl}}/api/users?page=1&page_size=10
Authorization: Bearer {{token}}

### Change role of another user (admin only)
PUT {{baseUrl}}/api/users/{{userId}}/role
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "role": "admin"
}

### Delete another user's account (admin only)
DELETE {{baseUrl}}/api/users/{{userId}}
Authorization: Bearer {{token}}

### Admin create user directly (admin/owner/root only)
POST {{baseUrl}}/api/users
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Pastor Benjamin",
  "email": "benjamin@gmail.com",
  "password": "qwer1234",
  "role": "pastor",
  "phone": "+123456789",
  "username": "pastorben"
}

###############################################################################
# Music (protected)
###############################################################################

### Create music
# @name createMusic
POST {{baseUrl}}/api/musics
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "ព្រះអទិករ",
  "artist": "John Newton",
  "album": "Hymns",
  "genre": "Hymn",
  "duration": 240,
  "bpm": 120,
  "key": "G",
  "cover": "https://example.com/covers/amazing-grace.jpg",
  "lyrics": "Amazing grace, how sweet the sound...",
  "description": "Classic hymn"
}

### Get all music
GET {{baseUrl}}/api/musics
Authorization: Bearer {{token}}

### Get all music (paginated)
GET {{baseUrl}}/api/musics?page=1&page_size=20
Authorization: Bearer {{token}}

### Get user's music
GET {{baseUrl}}/api/musics/user
Authorization: Bearer {{token}}

### Get music by ID
GET {{baseUrl}}/api/musics/{{musicId}}
Authorization: Bearer {{token}}

### Update music
PUT {{baseUrl}}/api/musics/{{musicId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Amazing Grace (Updated)",
  "artist": "John Newton",
  "album": "Hymns",
  "genre": "Hymn",
  "duration": 245,
  "bpm": 82,
  "key": "G",
  "cover": "https://example.com/covers/amazing-grace.jpg",
  "lyrics": "Amazing grace...",
  "description": "Updated description"
}

### Delete music
DELETE {{baseUrl}}/api/musics/{{musicId}}
Authorization: Bearer {{token}}

